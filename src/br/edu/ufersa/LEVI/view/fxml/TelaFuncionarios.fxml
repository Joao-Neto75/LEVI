<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<!--
    O StackPane raiz permite empilhar o modal (painelFormulario)
    sobre o BorderPane, cobrindo a tela inteira sem cortar.
-->
<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="br.edu.ufersa.LEVI.view.Controller.FuncionariosController"
           stylesheets="@../css/duduteca.css">

    <!-- ══════════════════  TELA PRINCIPAL  ══════════════════ -->
    <BorderPane prefHeight="650.0" prefWidth="1000.0">

        <!-- SIDEBAR -->
        <left>
            <VBox styleClass="sidebar" spacing="0">
                <padding><Insets top="30" right="20" bottom="30" left="24"/></padding>
                <children>
                    <Button onAction="#abrirDashboard" styleClass="sidebar-btn"
                            style="-fx-padding: 0; -fx-background-color: transparent;">
                        <graphic><Label text="DUDUTECA" styleClass="sidebar-title"/></graphic>
                        <VBox.margin><Insets bottom="36"/></VBox.margin>
                    </Button>
                    <Button text="Livros" styleClass="sidebar-btn" onAction="#abrirLivros" maxWidth="Infinity">
                        <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                            <image><Image url="@../icons/livro.png"/></image>
                        </ImageView></graphic>
                        <VBox.margin><Insets bottom="24"/></VBox.margin>
                    </Button>
                    <Button text="Discos" styleClass="sidebar-btn" onAction="#abrirDiscos" maxWidth="Infinity">
                        <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                            <image><Image url="@../icons/disco.png"/></image>
                        </ImageView></graphic>
                        <VBox.margin><Insets bottom="24"/></VBox.margin>
                    </Button>
                    <Button text="Clientes" styleClass="sidebar-btn" onAction="#abrirClientes" maxWidth="Infinity">
                        <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                            <image><Image url="@../icons/cliente.png"/></image>
                        </ImageView></graphic>
                        <VBox.margin><Insets bottom="24"/></VBox.margin>
                    </Button>
                    <Button text="Alugueis" styleClass="sidebar-btn" onAction="#abrirAlugueis" maxWidth="Infinity">
                        <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                            <image><Image url="@../icons/aluguel.png"/></image>
                        </ImageView></graphic>
                        <VBox.margin><Insets bottom="24"/></VBox.margin>
                    </Button>
                    <Button text="Relatório" styleClass="sidebar-btn" onAction="#abrirRelatorio" maxWidth="Infinity">
                        <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                            <image><Image url="@../icons/relatorio.png"/></image>
                        </ImageView></graphic>
                        <VBox.margin><Insets bottom="24"/></VBox.margin>
                    </Button>
                    <Button text="Funcionários" styleClass="sidebar-btn, sidebar-btn-active"
                            onAction="#abrirFuncionarios" maxWidth="Infinity">
                        <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                            <image><Image url="@../icons/cliente.png"/></image>
                        </ImageView></graphic>
                    </Button>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Button text="Sair" styleClass="sidebar-sair" onAction="#handleSair" maxWidth="Infinity"/>
                </children>
            </VBox>
        </left>

        <!-- CONTEÚDO -->
        <center>
            <VBox spacing="16.0">
                <padding><Insets top="30" right="35" bottom="30" left="35"/></padding>
                <children>
                    <Label text="Gerenciamento de Funcionários" styleClass="page-title"/>
                    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="search-bar">
                        <children>
                            <Label text="Nome:" style="-fx-font-size:13px;"/>
                            <TextField fx:id="campoBusca" promptText="Buscar por nome..."
                                       prefWidth="260" styleClass="search-field"/>
                            <Button text="🔍 Buscar" styleClass="search-btn" onAction="#handleBuscar"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Novo Funcionário +" styleClass="btn-primary" onAction="#handleAdicionar"/>
                        </children>
                    </HBox>
                    <Label fx:id="labelErro" styleClass="error-label"/>
                    <TableView fx:id="tabelaFuncionarios" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colNome"        text="Nome"        prefWidth="220" minWidth="130"/>
                            <TableColumn fx:id="colCargo"       text="Cargo"       prefWidth="130" minWidth="90"/>
                            <TableColumn fx:id="colEmail"       text="E-mail"      prefWidth="230" minWidth="150"/>
                            <TableColumn fx:id="colContratacao" text="Contratação" prefWidth="120" minWidth="90"/>
                            <TableColumn fx:id="colAcoes"       text="Ações"       prefWidth="90"  minWidth="70"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </children>
            </VBox>
        </center>

    </BorderPane>

    <!-- ══════════════════  MODAL (sobre a tela inteira)  ══════════════════ -->
    <StackPane fx:id="painelFormulario" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.45);">
        <children>
            <ScrollPane fitToWidth="true" maxHeight="580" maxWidth="500"
                        style="-fx-background: transparent; -fx-background-color: transparent;"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                <content>
                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E0D5C8; -fx-border-radius: 12;">
                        <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
                        <children>
                            <Label fx:id="labelTituloForm" text="Novo Funcionário"
                                   style="-fx-font-size:18px; -fx-font-weight:bold;"/>
                            <Separator/>
                            <Label text="Nome" style="-fx-font-size:12px;"/>
                            <TextField fx:id="fieldNome" promptText="Nome completo" styleClass="search-field"/>
                            <Label text="Cargo" style="-fx-font-size:12px;"/>
                            <ComboBox fx:id="comboCargo" promptText="Cargo" maxWidth="Infinity"/>
                            <Label text="Salário (R$)" style="-fx-font-size:12px;"/>
                            <TextField fx:id="fieldSalario" promptText="Ex: 1500.00" styleClass="search-field"/>
                            <Label text="E-mail" style="-fx-font-size:12px;"/>
                            <TextField fx:id="fieldEmail" promptText="E-mail" styleClass="search-field"/>
                            <Label text="Senha" style="-fx-font-size:12px;"/>
                            <PasswordField fx:id="fieldSenha" promptText="Senha" styleClass="search-field"/>
                            <Label text="Confirmar senha" style="-fx-font-size:12px;"/>
                            <PasswordField fx:id="fieldConfirma" promptText="Confirmar senha" styleClass="search-field"/>
                            <Label fx:id="labelErroForm" styleClass="error-label"/>
                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                <children>
                                    <Button text="Cancelar" styleClass="search-btn" onAction="#handleCancelar"/>
                                    <Button text="Salvar" styleClass="btn-primary" onAction="#handleSalvar"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </content>
            </ScrollPane>
        </children>
    </StackPane>

</StackPane>
