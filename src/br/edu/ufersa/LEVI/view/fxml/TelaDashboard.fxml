<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0" prefWidth="1000.0"
    stylesheets="@../css/duduteca.css"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.edu.ufersa.LEVI.view.Controller.DashboardController">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <padding><Insets top="30" right="20" bottom="30" left="24"/></padding>
            <children>
                <Button onAction="#abrirDashboard" styleClass="sidebar-btn" style="-fx-padding: 0; -fx-background-color: transparent;">
                    <graphic>
                        <Label text="DUDUTECA" styleClass="sidebar-title">
                            <VBox.margin><Insets bottom="36"/></VBox.margin>
                        </Label>
                    </graphic>
                    <VBox.margin><Insets bottom="36"/></VBox.margin>
                </Button>
                
                <Button fx:id="botaoLivros" text="Livros" styleClass="sidebar-btn"
                        onAction="#abrirLivros" maxWidth="Infinity">
                    <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                        <image><Image url="@../icons/livro.png"/></image>
                    </ImageView></graphic>
                    <VBox.margin><Insets bottom="24"/></VBox.margin>
                </Button>
                <Button fx:id="botaoDiscos" text="Discos" styleClass="sidebar-btn"
                        onAction="#abrirDiscos" maxWidth="Infinity">
                    <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                        <image><Image url="@../icons/disco.png"/></image>
                    </ImageView></graphic>
                    <VBox.margin><Insets bottom="24"/></VBox.margin>
                </Button>
                <Button fx:id="botaoClientes" text="Clientes" styleClass="sidebar-btn"
                        onAction="#abrirClientes" maxWidth="Infinity">
                    <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                        <image><Image url="@../icons/cliente.png"/></image>
                    </ImageView></graphic>
                    <VBox.margin><Insets bottom="24"/></VBox.margin>
                </Button>
                <Button fx:id="botaoAlugueis" text="Alugueis" styleClass="sidebar-btn"
                        onAction="#abrirAlugueis" maxWidth="Infinity">
                    <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                        <image><Image url="@../icons/aluguel.png"/></image>
                    </ImageView></graphic>
                    <VBox.margin><Insets bottom="24"/></VBox.margin>
                </Button>
                <Button fx:id="botaoRelatorio" text="Relatório" styleClass="sidebar-btn"
                        onAction="#abrirRelatorio" maxWidth="Infinity">
                    <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                        <image><Image url="@../icons/relatorio.png"/></image>
                    </ImageView></graphic>
                </Button>
                
                <Region VBox.vgrow="ALWAYS"/>
                <Button fx:id="botaoSair" text="Sair" styleClass="sidebar-sair"
                        onAction="#handleSair" maxWidth="Infinity"/>
            </children>
        </VBox>
    </left>

    <!-- TOPO -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #F4E9DD; -fx-border-color: transparent transparent #e0d5c8 transparent; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets bottom="15" left="30" right="30" top="20" />
            </padding>
            <children>
                <TextField fx:id="campoBusca" prefHeight="36.0" prefWidth="420.0" promptText="Buscar..." style="-fx-background-color: #2b2b2b; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-background-radius: 6; -fx-font-size: 13px; -fx-padding: 0 12 0 12;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="labelFuncionarioLogado" style="-fx-font-style: italic; -fx-font-size: 13px; -fx-text-fill: #555;" />
            </children>
        </HBox>
    </top>

    <!-- CARDS -->
    <center>
        <GridPane hgap="16.0" vgap="16.0">
            <padding>
                <Insets bottom="30" left="30" right="30" top="16" />
            </padding>
            <columnConstraints>
                <ColumnConstraints percentWidth="50" />
                <ColumnConstraints percentWidth="50" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints percentHeight="50" />
                <RowConstraints percentHeight="50" />
            </rowConstraints>
            <children>
                <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <padding>
                        <Insets bottom="15" left="18" right="18" top="15" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E1E1E;" text="Mais buscados" />
                        <ListView fx:id="listaMaisBuscados" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
                <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <padding>
                        <Insets bottom="15" left="18" right="18" top="15" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E1E1E;" text="Alugueis expirando" />
                        <ListView fx:id="listaAlugueisExpirando" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
                <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <padding>
                        <Insets bottom="15" left="18" right="18" top="15" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E1E1E;" text="Renovações automáticas" />
                        <ListView fx:id="listaRenovacoes" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
                <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <padding>
                        <Insets bottom="15" left="18" right="18" top="15" />
                    </padding>
                    <children>
                        <Label fx:id="labelVisaoGeralTitulo" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E1E1E;" text="Visão Geral" />
                        <Label fx:id="labelFaturamento" style="-fx-font-size: 13px; -fx-text-fill: #444;" text="Faturamento Total: R$ 0,00" />
                        <Label fx:id="labelAlugueisAtivos" style="-fx-font-size: 13px; -fx-text-fill: #444;" text="Aluguéis Ativos: 0" />
                        <Label fx:id="labelEstoque" style="-fx-font-size: 13px; -fx-text-fill: #444;" text="Total em Estoque: 0" />
                    </children>
                </VBox>
            </children>
        </GridPane>
    </center>
</BorderPane>
