<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0" prefWidth="1000.0"
            stylesheets="@../css/duduteca.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ufersa.LEVI.view.Controller.LivrosController">

    <left>
        <VBox styleClass="sidebar" spacing="0">
            <padding><Insets top="30" right="20" bottom="30" left="24"/></padding>
            <children>
                <Button onAction="#abrirDashboard" styleClass="sidebar-btn"
                        style="-fx-padding: 0; -fx-background-color: transparent;">
                    <graphic><Label text="DUDUTECA" styleClass="sidebar-title"/></graphic>
                    <VBox.margin><Insets bottom="36"/></VBox.margin>
                </Button>
                <Button text="Livros" styleClass="sidebar-btn, sidebar-btn-active" onAction="#abrirLivros" maxWidth="Infinity">
                    <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                        <image><Image url="@../icons/livro.png"/></image>
                    </ImageView></graphic>
                    <VBox.margin><Insets bottom="24"/></VBox.margin>
                </Button>
                <Button text="Discos" styleClass="sidebar-btn" onAction="#abrirDiscos" maxWidth="Infinity">
                    <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                        <image><Image url="@../icons/disco.png"/></image>
                    </ImageView></graphic>
                    <VBox.margin><Insets bottom="24"/></VBox.margin>
                </Button>
                <Button text="Clientes" styleClass="sidebar-btn" onAction="#abrirClientes" maxWidth="Infinity">
                    <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                        <image><Image url="@../icons/cliente.png"/></image>
                    </ImageView></graphic>
                    <VBox.margin><Insets bottom="24"/></VBox.margin>
                </Button>
                <Button text="Alugueis" styleClass="sidebar-btn" onAction="#abrirAlugueis" maxWidth="Infinity">
                    <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                        <image><Image url="@../icons/aluguel.png"/></image>
                    </ImageView></graphic>
                    <VBox.margin><Insets bottom="24"/></VBox.margin>
                </Button>
                <Button text="Relatório" styleClass="sidebar-btn" onAction="#abrirRelatorio" maxWidth="Infinity">
                    <graphic><ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                        <image><Image url="@../icons/relatorio.png"/></image>
                    </ImageView></graphic>
                </Button>
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="Sair" styleClass="sidebar-sair" onAction="#handleSair" maxWidth="Infinity"/>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="16.0">
            <padding><Insets top="30" right="35" bottom="30" left="35"/></padding>
            <children>
                <Label text="Gerenciamento de Livros" styleClass="page-title"/>

                <HBox spacing="12" alignment="CENTER_LEFT" styleClass="search-bar">
                    <children>
                        <Label text="Título:" style="-fx-font-size:13px;"/>
                        <TextField fx:id="campoBuscaTitulo" promptText="Nome..." prefWidth="180" styleClass="search-field"/>
                        <Label text="Gênero:" style="-fx-font-size:13px;"/>
                        <ComboBox fx:id="comboGenero" promptText="Gênero" prefWidth="140"/>
                        <Label text="Autor:" style="-fx-font-size:13px;"/>
                        <TextField fx:id="campoBuscaAutor" promptText="Nome..." prefWidth="160" styleClass="search-field"/>
                        <Button text="🔍 Buscar" styleClass="search-btn" onAction="#handleBuscar"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Adicionar Livro +" styleClass="btn-primary" onAction="#handleAdicionar"/>
                    </children>
                </HBox>

                <Label fx:id="labelErro" styleClass="error-label"/>

                <VBox fx:id="painelFormulario" spacing="10" visible="false" managed="false"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #E0D5C8; -fx-border-radius: 10;">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                    <children>
                        <Label fx:id="labelTituloForm" text="Adicionar Livro" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="4"><children><Label text="Título" style="-fx-font-size:12px;"/><TextField fx:id="fieldTitulo" prefWidth="180" styleClass="search-field"/></children></VBox>
                                <VBox spacing="4"><children><Label text="Autor" style="-fx-font-size:12px;"/><TextField fx:id="fieldAutor" prefWidth="160" styleClass="search-field"/></children></VBox>
                                <VBox spacing="4"><children><Label text="Gênero" style="-fx-font-size:12px;"/><TextField fx:id="fieldGenero" prefWidth="140" styleClass="search-field"/></children></VBox>
                                <VBox spacing="4"><children><Label text="Ano (AAAA-MM-DD)" style="-fx-font-size:12px;"/><TextField fx:id="fieldAno" prefWidth="120" styleClass="search-field"/></children></VBox>
                                <VBox spacing="4"><children><Label text="Páginas" style="-fx-font-size:12px;"/><TextField fx:id="fieldPaginas" prefWidth="80" styleClass="search-field"/></children></VBox>
                                <VBox spacing="4"><children><Label text="Exemplares" style="-fx-font-size:12px;"/><TextField fx:id="fieldExemplares" prefWidth="80" styleClass="search-field"/></children></VBox>
                                <VBox spacing="4"><children><Label text="Valor (R$)" style="-fx-font-size:12px;"/><TextField fx:id="fieldValor" prefWidth="80" styleClass="search-field"/></children></VBox>
                            </children>
                        </HBox>
                        <Label fx:id="labelErroForm" styleClass="error-label"/>
                        <HBox spacing="10">
                            <children>
                                <Button text="Salvar" styleClass="btn-primary" onAction="#handleSalvar"/>
                                <Button text="Cancelar" styleClass="search-btn" onAction="#handleCancelar"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <TableView fx:id="tabelaLivros" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colTitulo"     text="Título"           prefWidth="210"/>
                        <TableColumn fx:id="colAutor"      text="Autor"            prefWidth="150"/>
                        <TableColumn fx:id="colGenero"     text="Gênero"           prefWidth="140"/>
                        <TableColumn fx:id="colAno"        text="Ano"              prefWidth="70"/>
                        <TableColumn fx:id="colExemplares" text="Exemplares"       prefWidth="90"/>
                        <TableColumn fx:id="colValor"      text="Valor de Aluguel" prefWidth="120"/>
                        <TableColumn fx:id="colAcoes"      text="Ações"            prefWidth="80"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>
