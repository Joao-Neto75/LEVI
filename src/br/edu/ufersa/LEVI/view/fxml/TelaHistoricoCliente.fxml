<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="700.0" prefHeight="480.0"
            stylesheets="@../css/duduteca.css"
            style="-fx-background-color: #F4E9DD;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ufersa.LEVI.view.Controller.HistoricoClienteController">

    <!-- CABEÇALHO -->
    <top>
        <VBox style="-fx-background-color: #D4A537;" spacing="4">
            <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>
            <children>
                <Label fx:id="labelNomeCliente"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E1E1E;"
                       text="Histórico do Cliente"/>
                <HBox spacing="20">
                    <children>
                        <Label fx:id="labelCpf"
                               style="-fx-font-size: 13px; -fx-text-fill: #1E1E1E;" text="CPF: —"/>
                        <Label fx:id="labelEndereco"
                               style="-fx-font-size: 13px; -fx-text-fill: #1E1E1E;" text="Endereço: —"/>
                        <Label fx:id="labelStatus"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E1E1E;" text="Status: Regular"/>
                        <Label fx:id="labelTotalItens"
                               style="-fx-font-size: 13px; -fx-text-fill: #1E1E1E;" text="Itens: 0"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <!-- TABELA DE ALUGUEIS -->
    <center>
        <VBox spacing="12">
            <padding><Insets top="20" right="24" bottom="12" left="24"/></padding>
            <children>
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333;"
                       text="Histórico de Alugueis"/>

                <TableView fx:id="tabelaHistorico" VBox.vgrow="ALWAYS" maxHeight="Infinity"
                           styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colTipo"      text="Tipo"       prefWidth="70"  minWidth="60"/>
                        <TableColumn fx:id="colProduto"   text="Produto"    prefWidth="200" minWidth="140"/>
                        <TableColumn fx:id="colEmprestimo" text="Empréstimo" prefWidth="110" minWidth="90"/>
                        <TableColumn fx:id="colDevolucao" text="Devolução"  prefWidth="110" minWidth="90"/>
                        <TableColumn fx:id="colStatus"    text="Status"     prefWidth="100" minWidth="80"/>
                        <TableColumn fx:id="colValor"     text="Valor"      prefWidth="90"  minWidth="70"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <!-- Rodapé com totais -->
                <HBox spacing="24" alignment="CENTER_RIGHT"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 10 16 10 16;">
                    <children>
                        <Label fx:id="labelTotalAlugueis"
                               style="-fx-font-size: 13px; -fx-text-fill: #555;" text="Total de alugueis: 0"/>
                        <Label fx:id="labelMulta"
                               style="-fx-font-size: 13px; -fx-text-fill: #cc0000; -fx-font-weight: bold;"
                               text="Multa por atraso: R$ 0,00"/>
                        <Label fx:id="labelTotalValor"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E1E1E;"
                               text="Valor total: R$ 0,00"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <!-- BOTÃO FECHAR -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding><Insets top="8" right="24" bottom="16" left="24"/></padding>
            <children>
                <Button onAction="#handleFechar" styleClass="btn-primary" text="Fechar"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>
